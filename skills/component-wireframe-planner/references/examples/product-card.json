{
  "id": "product-card-example",
  "type": "wireframe",
  "label": "Product Card Component Example",
  "version": "0.1.0",
  "root": {
    "id": "product-card",
    "type": "card",
    "label": "Product Card",
    "children": [
      {
        "id": "product-image",
        "type": "imagePlaceholder",
        "label": "Product Image"
      },
      {
        "id": "product-name",
        "type": "heading",
        "label": "Product Name",
        "role": "headline"
      },
      {
        "id": "product-description",
        "type": "paragraph",
        "label": "Product Description",
        "role": "body"
      },
      {
        "id": "product-card-action",
        "type": "button",
        "label": "View Product",
        "role": "primaryCTA"
      }
    ]
  },
  "responsive": {
    "desktop": "Card content is vertically stacked with fixed media ratio.",
    "tablet": "Card maintains the same structure.",
    "mobile": "Card spans full available width."
  }
}
