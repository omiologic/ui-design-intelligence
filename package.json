{
  "name": "ui-design-intelligence",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "validate": "npm run check:schema && npm run build:valid-node-types && npm run validate:skills && npm run validate:examples && npm run validate:taste-profiles && npm run validate:quality-golden-set && npm run validate:knowledge && npm run validate:design-system && npm run validate:prototype && npm run validate:style-references && npm run validate:knowledge-index && npm run validate:knowledge-workspace-init && npm run validate:blueprint-antipatterns && npm run validate:invalid-examples && npm run validate:invalid-taste-profiles && npm run validate:invalid-antipatterns && npm run validate:bundles && npm run validate:capture-url && npm run validate:export-seed",
    "validate:skills": "node scripts/validate-skills.mjs",
    "validate:skills:canonical": "node scripts/validate-skills.mjs --strict-canonical",
    "validate:examples": "node scripts/validate-examples.mjs",
    "validate:taste-profiles": "node scripts/validate-taste-profiles.mjs",
    "validate:quality-golden-set": "node scripts/validate-quality-golden-set.mjs",
    "validate:knowledge": "node scripts/validate-knowledge.mjs",
    "validate:design-system": "node scripts/validate-design-system.mjs",
    "validate:prototype": "node scripts/validate-prototype.mjs",
    "validate:style-references": "node scripts/validate-style-references.mjs",
    "validate:knowledge-index": "node scripts/index-knowledge.mjs --patterns knowledge/examples --out knowledge/examples/knowledge-index.example.json --check",
    "validate:knowledge-workspace-init": "node scripts/init-knowledge-workspace.mjs --out /tmp/ui-knowledge-init-check --check",
    "validate:blueprint-antipatterns": "node scripts/validate-blueprint-antipatterns.mjs",
    "validate:invalid-examples": "node scripts/validate-invalid-examples.mjs",
    "validate:invalid-taste-profiles": "node scripts/validate-invalid-taste-profiles.mjs",
    "validate:invalid-antipatterns": "node scripts/validate-invalid-antipatterns.mjs",
    "validate:bundles": "node scripts/validate-bundles.mjs",
    "validate:bundles:strict": "node scripts/validate-bundles.mjs --strict",
    "validate:release": "node scripts/validate-release.mjs",
    "validate:capture-url": "node scripts/capture-url.mjs --url https://example.com --captured-at 2026-06-29 --check",
    "validate:export-seed": "node scripts/export-blueprint-seed.mjs --blueprint shared/examples/ui-blueprint.example.json --profile shared/taste-profiles/conversion.json --expect shared/examples/ui-blueprint.export-seed.md --check",
    "build:bundles": "node scripts/build-bundles.mjs",
    "build:schema": "node scripts/build-schema.mjs",
    "check:schema": "node scripts/check-schema-drift.mjs",
    "build:valid-node-types": "node scripts/build-valid-node-types.mjs",
    "verify:installed-references": "node scripts/verify-installed-references.mjs",
    "package": "node scripts/build-zip.mjs"
  }
}
