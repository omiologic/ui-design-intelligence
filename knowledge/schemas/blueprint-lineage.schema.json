{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omiologic.dev/schemas/ui-blueprint/knowledge/blueprint-lineage.schema.json",
  "title": "UI Blueprint Lineage",
  "description": "Traceability record explaining which pattern knowledge influenced a generated blueprint.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "blueprintId", "createdAt", "query", "usedPatterns", "generatedOutputs"],
  "properties": {
    "id": { "$ref": "#/$defs/id" },
    "type": { "const": "blueprintLineage" },
    "blueprintId": { "$ref": "#/$defs/id" },
    "createdAt": { "type": "string", "minLength": 1 },
    "query": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "industry": { "type": "string" },
        "pageType": { "type": "string" },
        "sectionType": { "type": "string" },
        "conversionGoal": { "type": "string" },
        "audience": { "type": "string" },
        "brief": { "type": "string" }
      }
    },
    "usedPatterns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["patternId", "usedFor", "reason"],
        "properties": {
          "patternId": { "$ref": "#/$defs/id" },
          "usedFor": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "sourceRefs": { "$ref": "#/$defs/stringList" },
          "storageRef": { "$ref": "#/$defs/storageRef" }
        }
      }
    },
    "generatedOutputs": { "$ref": "#/$defs/pathList" },
    "generatedOutputRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "storageRef": { "$ref": "#/$defs/storageRef" }
        }
      }
    },
    "storageRef": { "$ref": "#/$defs/storageRef" },
    "assumptions": { "$ref": "#/$defs/stringList" },
    "unresolvedGaps": { "$ref": "#/$defs/stringList" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$" },
    "stringList": { "type": "array", "items": { "type": "string", "minLength": 1 }, "default": [] },
    "pathList": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
    "storageRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "uri"],
      "properties": {
        "kind": { "type": "string", "enum": ["localPath", "s3Uri"] },
        "uri": { "type": "string", "minLength": 1 },
        "objectType": {
          "type": "string",
          "enum": ["sourceRecord", "studyRecord", "auditRecord", "patternRecord", "knowledgeIndex", "blueprintLineage", "generatedOutput"]
        },
        "etag": { "type": "string", "minLength": 1 },
        "versionId": { "type": "string", "minLength": 1 },
        "updatedAt": { "type": "string", "minLength": 1 },
        "checksum": {
          "type": "object",
          "additionalProperties": false,
          "required": ["algorithm", "value"],
          "properties": {
            "algorithm": { "type": "string", "enum": ["sha256"] },
            "value": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
