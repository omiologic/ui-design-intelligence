{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omiologic.dev/schemas/ui-blueprint/knowledge/voice-profile.schema.json",
  "title": "Voice Profile Knowledge Record",
  "description": "Reusable brand or domain voice profile for UX content and prototype copy generation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "name", "summary", "tags", "tone", "avoid", "rules", "sourceRefs", "confidence", "status"],
  "properties": {
    "id": { "$ref": "#/$defs/id" },
    "type": { "const": "voiceProfile" },
    "name": { "$ref": "#/$defs/label" },
    "summary": { "$ref": "#/$defs/label" },
    "tags": { "$ref": "#/$defs/contentTags" },
    "tone": { "$ref": "#/$defs/stringListRequired" },
    "avoid": { "$ref": "#/$defs/stringListRequired" },
    "preferredTerms": { "$ref": "#/$defs/stringList" },
    "restrictedTerms": { "$ref": "#/$defs/stringList" },
    "ctaVerbs": { "$ref": "#/$defs/stringList" },
    "rules": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/voiceRule" } },
    "reviewRisks": { "type": "array", "items": { "$ref": "#/$defs/reviewRisk" }, "default": [] },
    "sourceRefs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/sourceRef" } },
    "storageRef": { "$ref": "#/$defs/storageRef" },
    "confidence": { "$ref": "#/$defs/confidence" },
    "status": { "$ref": "#/$defs/status" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$" },
    "label": { "type": "string", "minLength": 1 },
    "stringList": { "type": "array", "items": { "type": "string", "minLength": 1 }, "default": [] },
    "stringListRequired": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "status": { "type": "string", "enum": ["candidate", "accepted", "validated", "deprecated", "merged"] },
    "confidenceLevel": { "type": "string", "enum": ["low", "medium", "high", "validated"] },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "reason"],
      "properties": {
        "level": { "$ref": "#/$defs/confidenceLevel" },
        "reason": { "$ref": "#/$defs/label" }
      }
    },
    "reviewRisk": {
      "type": "string",
      "enum": ["medicalClaims", "pricingAccuracy", "productSpecs", "legalCompliance", "financialClaims", "brandApproval", "clientApproval", "accessibilityLanguage", "translationReview"]
    },
    "contentTags": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "industries": { "$ref": "#/$defs/stringList" },
        "pageTypes": { "$ref": "#/$defs/stringList" },
        "audiences": { "$ref": "#/$defs/stringList" },
        "voiceTraits": { "$ref": "#/$defs/stringList" },
        "conversionGoals": { "$ref": "#/$defs/stringList" }
      }
    },
    "voiceRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "rule", "reason"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "rule": { "$ref": "#/$defs/label" },
        "reason": { "$ref": "#/$defs/label" },
        "appliesTo": { "$ref": "#/$defs/stringList" }
      }
    },
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceId"],
      "properties": {
        "sourceId": { "$ref": "#/$defs/id" },
        "studyId": { "$ref": "#/$defs/id" },
        "patternId": { "$ref": "#/$defs/id" },
        "evidenceRefs": { "$ref": "#/$defs/stringList" },
        "storageRef": { "$ref": "#/$defs/storageRef" }
      }
    },
    "storageRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "uri"],
      "properties": {
        "kind": { "type": "string", "enum": ["localPath", "s3Uri"] },
        "uri": { "type": "string", "minLength": 1 },
        "objectType": { "type": "string", "enum": ["copyPattern", "journeyPattern", "objectionPattern", "voiceProfile"] },
        "etag": { "type": "string", "minLength": 1 },
        "versionId": { "type": "string", "minLength": 1 },
        "updatedAt": { "type": "string", "minLength": 1 }
      }
    }
  }
}
