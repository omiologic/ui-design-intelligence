{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omiologic.dev/schemas/ui-blueprint/knowledge/audit-insight.schema.json",
  "title": "UI Audit Insight",
  "description": "Reusable audit-derived observation that may become or support a pattern record.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "auditType", "title", "severity", "category", "insight", "evidence", "recommendation", "sourceRefs"],
  "properties": {
    "id": { "$ref": "#/$defs/id" },
    "type": { "const": "auditInsight" },
    "auditType": { "type": "string", "enum": ["site", "page", "section", "interaction", "accessibility", "seo"] },
    "title": { "$ref": "#/$defs/label" },
    "severity": { "type": "string", "enum": ["info", "low", "medium", "high", "critical"] },
    "category": { "type": "string", "enum": ["storytelling", "structure", "interaction", "accessibility", "responsive", "seo", "content", "conversion"] },
    "insight": { "type": "string", "minLength": 1 },
    "evidence": { "type": "string", "minLength": 1 },
    "recommendation": { "type": "string", "minLength": 1 },
    "patternCandidateIds": { "type": "array", "items": { "$ref": "#/$defs/id" }, "default": [] },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sourceId"],
        "properties": {
          "sourceId": { "$ref": "#/$defs/id" },
          "auditId": { "$ref": "#/$defs/id" },
          "findingId": { "$ref": "#/$defs/id" },
          "evidenceRefs": { "$ref": "#/$defs/stringList" }
        }
      }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$" },
    "label": { "type": "string", "minLength": 1 },
    "stringList": { "type": "array", "items": { "type": "string", "minLength": 1 }, "default": [] }
  }
}
