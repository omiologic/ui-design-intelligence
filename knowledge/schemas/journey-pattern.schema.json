{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omiologic.dev/schemas/ui-blueprint/knowledge/journey-pattern.schema.json",
  "title": "Journey Pattern Knowledge Record",
  "description": "Reusable user journey pattern for mapping goals, stages, objections, recommended sections, and copy strategy.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "name", "summary", "tags", "primaryGoal", "stages", "sourceRefs", "confidence", "status"],
  "properties": {
    "id": { "$ref": "#/$defs/id" },
    "type": { "const": "journeyPattern" },
    "name": { "$ref": "#/$defs/label" },
    "summary": { "$ref": "#/$defs/label" },
    "tags": { "$ref": "#/$defs/contentTags" },
    "primaryGoal": { "$ref": "#/$defs/id" },
    "useWhen": { "$ref": "#/$defs/stringList" },
    "avoidWhen": { "$ref": "#/$defs/stringList" },
    "stages": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/journeyStage" } },
    "recommendedArtifacts": { "$ref": "#/$defs/stringList" },
    "sourceRefs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/sourceRef" } },
    "storageRef": { "$ref": "#/$defs/storageRef" },
    "confidence": { "$ref": "#/$defs/confidence" },
    "status": { "$ref": "#/$defs/status" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$" },
    "label": { "type": "string", "minLength": 1 },
    "stringList": { "type": "array", "items": { "type": "string", "minLength": 1 }, "default": [] },
    "status": { "type": "string", "enum": ["candidate", "accepted", "validated", "deprecated", "merged"] },
    "confidenceLevel": { "type": "string", "enum": ["low", "medium", "high", "validated"] },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "reason"],
      "properties": {
        "level": { "$ref": "#/$defs/confidenceLevel" },
        "reason": { "$ref": "#/$defs/label" }
      }
    },
    "contentTags": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "industries": { "$ref": "#/$defs/stringList" },
        "pageTypes": { "$ref": "#/$defs/stringList" },
        "conversionGoals": { "$ref": "#/$defs/stringList" },
        "audiences": { "$ref": "#/$defs/stringList" },
        "journeyStages": { "$ref": "#/$defs/stringList" },
        "objectionTypes": { "$ref": "#/$defs/stringList" }
      }
    },
    "journeyStage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "userQuestion", "userNeed", "contentGoal", "copyStrategy"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "label": { "$ref": "#/$defs/label" },
        "userQuestion": { "$ref": "#/$defs/label" },
        "userNeed": { "$ref": "#/$defs/label" },
        "contentGoal": { "$ref": "#/$defs/label" },
        "recommendedSections": { "$ref": "#/$defs/stringList" },
        "recommendedNodeRoles": { "$ref": "#/$defs/stringList" },
        "copyStrategy": { "$ref": "#/$defs/label" },
        "objections": { "$ref": "#/$defs/stringList" },
        "successCriteria": { "$ref": "#/$defs/stringList" }
      }
    },
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceId"],
      "properties": {
        "sourceId": { "$ref": "#/$defs/id" },
        "studyId": { "$ref": "#/$defs/id" },
        "patternId": { "$ref": "#/$defs/id" },
        "evidenceRefs": { "$ref": "#/$defs/stringList" },
        "storageRef": { "$ref": "#/$defs/storageRef" }
      }
    },
    "storageRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "uri"],
      "properties": {
        "kind": { "type": "string", "enum": ["localPath", "s3Uri"] },
        "uri": { "type": "string", "minLength": 1 },
        "objectType": { "type": "string", "enum": ["copyPattern", "journeyPattern", "objectionPattern", "voiceProfile"] },
        "etag": { "type": "string", "minLength": 1 },
        "versionId": { "type": "string", "minLength": 1 },
        "updatedAt": { "type": "string", "minLength": 1 }
      }
    }
  }
}
