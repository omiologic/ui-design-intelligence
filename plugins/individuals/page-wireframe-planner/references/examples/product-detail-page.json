{
  "id": "product-detail-page-example",
  "type": "wireframe",
  "label": "Product Detail Page Example",
  "version": "0.1.0",
  "root": {
    "id": "product-detail-page",
    "type": "page",
    "label": "Product Detail Page",
    "children": [
      {
        "id": "site-header",
        "type": "header",
        "label": "Store Header"
      },
      {
        "id": "product-main",
        "type": "main",
        "label": "Product Main",
        "children": [
          {
            "id": "product-breadcrumb",
            "type": "breadcrumb",
            "label": "Product Breadcrumb"
          },
          {
            "id": "product-hero",
            "type": "section",
            "label": "Product Hero",
            "layout": "twoColumn"
          },
          {
            "id": "product-details-tabs",
            "type": "tabs",
            "label": "Product Details Tabs",
            "children": [
              {
                "id": "overview-tab-panel",
                "type": "contentGroup",
                "label": "Overview Tab Panel"
              },
              {
                "id": "specifications-tab-panel",
                "type": "contentGroup",
                "label": "Specifications Tab Panel"
              }
            ]
          },
          {
            "id": "related-products",
            "type": "section",
            "label": "Related Products",
            "layout": "cardGrid"
          }
        ]
      },
      {
        "id": "site-footer",
        "type": "footer",
        "label": "Store Footer"
      }
    ]
  },
  "overlays": [
    {
      "id": "cart-drawer",
      "type": "drawer",
      "label": "Cart Drawer",
      "state": "closed"
    }
  ]
}
