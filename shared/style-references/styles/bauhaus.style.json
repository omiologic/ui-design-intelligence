    "effects": ["minimal effects and high clarity"],
    "layout": ["grid-led asymmetric balance"],
    "imagery": ["simple product crops and geometric annotation"]
  },
  "mood": ["clear", "rational", "modern", "systematic"],
  "bestFor": ["education pages", "portfolio systems", "product explainers"],
  "avoidFor": ["soft luxury pages", "emotion-led wellness pages"],
