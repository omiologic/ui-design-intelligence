{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omiologic.dev/schemas/ui-blueprint/card-foundation.schema.json",
  "title": "Card Foundation",
  "type": "object",
  "additionalProperties": false,
  "required": ["base", "anatomy", "variants", "rules", "source", "confidence"],
  "properties": {
    "base": { "type": "object", "additionalProperties": { "type": ["string", "number", "boolean"] } },
    "anatomy": { "type": "array", "items": { "type": "string" } },
    "variants": { "type": "object", "additionalProperties": { "$ref": "#/$defs/cardVariant" } },
    "rules": { "type": "array", "items": { "type": "string" } },
    "source": { "type": "string", "enum": ["observed", "inferred", "recommended", "generated", "userProvided"] },
    "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
    "note": { "type": "string" }
  },
  "$defs": {
    "cardVariant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["usage", "requiredParts"],
      "properties": {
        "usage": { "type": "string", "minLength": 1 },
        "requiredParts": { "type": "array", "items": { "type": "string" } },
        "allowedActions": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
