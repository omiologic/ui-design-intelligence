{
  "version": "0.1.0",
  "type": "prototypeConfig",
  "id": "claimstart-intake-prototype",
  "name": "ClaimStart Intake Prototype",
  "source": {
    "sourceWireframeId": "claimstart-intake-wireframe",
    "sourceWireframeRef": ".convention/examples/multi-step-form-e2e/multi-step-form.ui-blueprint.json",
    "sourceDesignSystemSeedId": "claimstart-form-design-system-seed",
    "notes": ["Prototype config models step behavior and does not implement claim submission."]
  },
  "designSystemSeedRef": "claimstart-form-design-system-seed",
  "screens": [
    {
      "id": "policy-step-screen",
      "label": "Policy Contact Step",
      "wireframeRef": "claimstart-intake-page",
      "routeId": "policy-step-route",
      "initialState": "default",
      "viewportPriority": ["expanded", "compact"]
    },
    {
      "id": "incident-step-screen",
      "label": "Incident Details Step",
      "wireframeRef": "claimstart-intake-page",
      "routeId": "incident-step-route",
      "initialState": "default",
      "viewportPriority": ["expanded", "compact"]
    },
    {
      "id": "review-step-screen",
      "label": "Review Step",
      "wireframeRef": "claimstart-intake-page",
      "routeId": "review-step-route",
      "initialState": "default",
      "viewportPriority": ["expanded", "compact"]
    },
    {
      "id": "success-step-screen",
      "label": "Success Step",
      "wireframeRef": "claimstart-intake-page",
      "routeId": "success-step-route",
      "initialState": "success",
      "viewportPriority": ["expanded", "compact"]
    }
  ],
  "routes": [
    {
      "id": "policy-step-route",
      "path": "/claim/policy",
      "screenId": "policy-step-screen",
      "label": "Policy"
    },
    {
      "id": "incident-step-route",
      "path": "/claim/incident",
      "screenId": "incident-step-screen",
      "label": "Incident"
    },
    {
      "id": "review-step-route",
      "path": "/claim/review",
      "screenId": "review-step-screen",
      "label": "Review"
    },
    {
      "id": "success-step-route",
      "path": "/claim/success",
      "screenId": "success-step-screen",
      "label": "Success"
    }
  ],
  "states": [
    {
      "id": "policy-step-required",
      "name": "Policy Step Required",
      "state": "required",
      "nodeId": "policy-contact-form",
      "screenId": "policy-step-screen",
      "description": "Policy and contact fields are required."
    },
    {
      "id": "policy-step-error",
      "name": "Policy Step Error",
      "state": "error",
      "nodeId": "policy-error-summary",
      "screenId": "policy-step-screen",
      "description": "Policy step shows inline and summary validation errors."
    },
    {
      "id": "policy-step-success-state",
      "name": "Policy Step Success",
      "state": "success",
      "nodeId": "policy-step-success",
      "screenId": "policy-step-screen",
      "description": "Policy step is complete."
    },
    {
      "id": "incident-step-required",
      "name": "Incident Step Required",
      "state": "required",
      "nodeId": "incident-details-form",
      "screenId": "incident-step-screen",
      "description": "Incident details and upload guidance are required."
    },
    {
      "id": "incident-step-error",
      "name": "Incident Step Error",
      "state": "error",
      "nodeId": "incident-error-summary",
      "screenId": "incident-step-screen",
      "description": "Incident step shows missing detail or upload failure."
    },
    {
      "id": "incident-step-success-state",
      "name": "Incident Step Success",
      "state": "success",
      "nodeId": "incident-step-success",
      "screenId": "incident-step-screen",
      "description": "Incident step is complete."
    },
    {
      "id": "review-step-default",
      "name": "Review Step Default",
      "state": "default",
      "nodeId": "review-summary-card",
      "screenId": "review-step-screen",
      "description": "Review summary is visible before submission."
    },
    {
      "id": "claim-submit-loading",
      "name": "Claim Submit Loading",
      "state": "loading",
      "nodeId": "submit-claim-button",
      "screenId": "review-step-screen",
      "description": "Claim submission is in progress."
    },
    {
      "id": "claim-submit-success",
      "name": "Claim Submit Success",
      "state": "success",
      "nodeId": "success-confirmation-card",
      "screenId": "success-step-screen",
      "description": "Claim submission succeeded."
    },
    {
      "id": "save-dialog-closed",
      "name": "Save Dialog Closed",
      "state": "closed",
      "nodeId": "save-resume-dialog",
      "screenId": "policy-step-screen",
      "description": "Save and resume dialog is not visible."
    },
    {
      "id": "save-dialog-open",
      "name": "Save Dialog Open",
      "state": "open",
      "nodeId": "save-resume-dialog",
      "screenId": "policy-step-screen",
      "description": "Save and resume dialog is visible and holds focus."
    },
    {
      "id": "mobile-progress-visible",
      "name": "Mobile Progress Visible",
      "state": "visible",
      "nodeId": "mobile-progress-sticky-bar",
      "screenId": "policy-step-screen",
      "description": "Mobile progress and save controls remain visible."
    }
  ],
  "componentStateModels": [
    {
      "id": "policy-form-state-model",
      "component": "form",
      "nodeId": "policy-contact-form",
      "wireframeRef": "claimstart-intake-page",
      "initialState": "required",
      "allowedStates": ["required", "error", "success"],
      "transitions": [
        {
          "from": "required",
          "to": "error",
          "trigger": "submit",
          "description": "Submitting missing policy fields shows errors."
        },
        {
          "from": "error",
          "to": "success",
          "trigger": "change",
          "description": "Completing required fields clears errors."
        }
      ],
      "validation": {
        "states": ["error", "success"],
        "errorPlacement": "summary",
        "rules": ["Policy number, name, and contact method are required."]
      },
      "accessibility": {
        "focusManagement": "Move focus to the error summary when validation fails.",
        "keyboardBehavior": "Enter or button activation submits the current step."
      }
    },
    {
      "id": "incident-form-state-model",
      "component": "form",
      "nodeId": "incident-details-form",
      "wireframeRef": "claimstart-intake-page",
      "initialState": "required",
      "allowedStates": ["required", "error", "success"],
      "transitions": [
        {
          "from": "required",
          "to": "error",
          "trigger": "submit",
          "description": "Submitting missing incident details or failed upload shows errors."
        },
        {
          "from": "error",
          "to": "success",
          "trigger": "change",
          "description": "Completing incident details clears errors."
        }
      ],
      "validation": {
        "states": ["error", "success"],
        "errorPlacement": "summary",
        "rules": ["Incident date, location, description, and upload status are checked."]
      },
      "accessibility": {
        "focusManagement": "Move focus to incident error summary when validation fails.",
        "keyboardBehavior": "Back and continue controls remain keyboard reachable."
      }
    },
    {
      "id": "save-resume-dialog-state-model",
      "component": "dialog",
      "nodeId": "save-resume-dialog",
      "wireframeRef": "claimstart-intake-page",
      "initialState": "closed",
      "allowedStates": ["closed", "open"],
      "transitions": [
        {
          "from": "closed",
          "to": "open",
          "trigger": "click",
          "description": "Save progress opens the resume dialog."
        },
        {
          "from": "open",
          "to": "closed",
          "trigger": "keydown",
          "description": "Escape closes the resume dialog."
        }
      ],
      "accessibility": {
        "focusManagement": "Move focus into the dialog on open and return focus to save progress on close.",
        "keyboardBehavior": "Escape closes the dialog; Tab remains inside while open.",
        "ariaLabel": "Save claim progress"
      }
    }
  ],
  "interactions": [
    {
      "id": "policy-validation-error",
      "label": "Show policy validation errors",
      "trigger": {
        "event": "submit",
        "sourceNodeId": "continue-to-incident-button",
        "screenId": "policy-step-screen",
        "routeId": "policy-step-route"
      },
      "condition": {
        "type": "whenInvalid",
        "stateId": "policy-step-required"
      },
      "action": {
        "type": "validateField",
        "targetNodeId": "policy-contact-form",
        "targetStateId": "policy-step-error"
      },
      "result": {
        "type": "validationShown",
        "description": "Policy validation summary appears and focus moves to it.",
        "resultingStateId": "policy-step-error",
        "focusTargetNodeId": "policy-error-summary"
      },
      "accessibility": {
        "focusManagement": "Move focus to policy error summary.",
        "keyboardBehavior": "Errors are reachable by keyboard.",
        "ariaLive": "polite"
      }
    },
    {
      "id": "continue-to-incident",
      "label": "Continue to incident step",
      "trigger": {
        "event": "submit",
        "sourceNodeId": "continue-to-incident-button",
        "screenId": "policy-step-screen",
        "routeId": "policy-step-route"
      },
      "condition": {
        "type": "whenValid",
        "stateId": "policy-step-success-state"
      },
      "action": {
        "type": "navigate",
        "targetScreenId": "incident-step-screen",
        "targetRouteId": "incident-step-route"
      },
      "result": {
        "type": "routeChanged",
        "description": "User advances to incident details without losing policy data.",
        "focusTargetNodeId": "incident-details-form"
      },
      "accessibility": {
        "focusManagement": "Move focus to incident step heading or form.",
        "keyboardBehavior": "Continue button submits the current step.",
        "ariaLive": "polite"
      }
    },
    {
      "id": "continue-to-review",
      "label": "Continue to review step",
      "trigger": {
        "event": "submit",
        "sourceNodeId": "continue-to-review-button",
        "screenId": "incident-step-screen",
        "routeId": "incident-step-route"
      },
      "condition": {
        "type": "whenValid",
        "stateId": "incident-step-success-state"
      },
      "action": {
        "type": "navigate",
        "targetScreenId": "review-step-screen",
        "targetRouteId": "review-step-route"
      },
      "result": {
        "type": "routeChanged",
        "description": "User advances to review with entered data preserved.",
        "focusTargetNodeId": "review-summary-card"
      },
      "accessibility": {
        "focusManagement": "Move focus to review summary.",
        "keyboardBehavior": "Continue button submits the incident step.",
        "ariaLive": "polite"
      }
    },
    {
      "id": "backtrack-to-incident",
      "label": "Backtrack from review to incident",
      "trigger": {
        "event": "click",
        "sourceNodeId": "edit-incident-button",
        "screenId": "review-step-screen",
        "routeId": "review-step-route"
      },
      "condition": {
        "type": "always"
      },
      "action": {
        "type": "navigate",
        "targetScreenId": "incident-step-screen",
        "targetRouteId": "incident-step-route"
      },
      "result": {
        "type": "routeChanged",
        "description": "User returns to incident step with previous values preserved.",
        "focusTargetNodeId": "incident-details-form"
      },
      "accessibility": {
        "focusManagement": "Move focus to incident form.",
        "keyboardBehavior": "Edit action is keyboard reachable.",
        "ariaLive": "polite"
      }
    },
    {
      "id": "submit-reviewed-claim",
      "label": "Submit reviewed claim",
      "trigger": {
        "event": "submit",
        "sourceNodeId": "submit-claim-button",
        "screenId": "review-step-screen",
        "routeId": "review-step-route"
      },
      "condition": {
        "type": "whenValid",
        "stateId": "review-step-default"
      },
      "action": {
        "type": "navigate",
        "targetScreenId": "success-step-screen",
        "targetRouteId": "success-step-route",
        "targetStateId": "claim-submit-loading"
      },
      "result": {
        "type": "routeChanged",
        "description": "Claim submits and success confirmation appears.",
        "resultingStateId": "claim-submit-success",
        "focusTargetNodeId": "success-confirmation-card"
      },
      "accessibility": {
        "focusManagement": "Move focus to success confirmation.",
        "keyboardBehavior": "Submit button sends the reviewed claim.",
        "ariaLive": "polite"
      }
    },
    {
      "id": "open-save-resume-dialog",
      "label": "Open save and resume dialog",
      "trigger": {
        "event": "click",
        "sourceNodeId": "save-progress-button",
        "screenId": "policy-step-screen",
        "routeId": "policy-step-route"
      },
      "condition": {
        "type": "always"
      },
      "action": {
        "type": "openOverlay",
        "targetNodeId": "save-resume-dialog",
        "targetStateId": "save-dialog-open"
      },
      "result": {
        "type": "overlayOpened",
        "description": "Save and resume dialog opens without discarding current progress.",
        "resultingStateId": "save-dialog-open",
        "focusTargetNodeId": "save-resume-dialog"
      },
      "accessibility": {
        "focusManagement": "Move focus into save dialog.",
        "keyboardBehavior": "Escape closes the dialog.",
        "ariaLive": "off"
      }
    }
  ],
  "overlays": [
    {
      "id": "save-resume-overlay",
      "nodeId": "save-resume-dialog",
      "type": "dialog",
      "initialState": "closed",
      "triggerNodeIds": ["save-progress-button", "mobile-save-button"],
      "dismissal": {
        "methods": ["escape", "closeButton", "scrim"],
        "focusReturnNodeId": "save-progress-button"
      }
    }
  ],
  "forms": [
    {
      "id": "policy-contact-form-model",
      "nodeId": "policy-contact-form",
      "fields": [
        {
          "id": "policy-fields-model",
          "nodeId": "policy-fields",
          "required": true,
          "validationStateIds": ["policy-step-error"]
        }
      ],
      "submitNodeId": "continue-to-incident-button",
      "validation": {
        "states": ["error", "success"],
        "errorPlacement": "summary",
        "rules": ["Policy number, name, and contact method are required."]
      }
    },
    {
      "id": "incident-details-form-model",
      "nodeId": "incident-details-form",
      "fields": [
        {
          "id": "incident-fields-model",
          "nodeId": "incident-fields",
          "required": true,
          "validationStateIds": ["incident-step-error"]
        },
        {
          "id": "photo-upload-fields-model",
          "nodeId": "photo-upload-fields",
          "required": false,
          "validationStateIds": ["incident-step-error"]
        }
      ],
      "submitNodeId": "continue-to-review-button",
      "validation": {
        "states": ["error", "success"],
        "errorPlacement": "summary",
        "rules": ["Incident date, location, and description are required.", "Upload failures remain recoverable."]
      }
    }
  ],
  "navigationFlows": [
    {
      "id": "policy-to-incident-flow",
      "fromScreenId": "policy-step-screen",
      "toScreenId": "incident-step-screen",
      "triggerNodeId": "continue-to-incident-button",
      "action": "navigate"
    },
    {
      "id": "incident-to-review-flow",
      "fromScreenId": "incident-step-screen",
      "toScreenId": "review-step-screen",
      "triggerNodeId": "continue-to-review-button",
      "action": "navigate"
    },
    {
      "id": "review-to-success-flow",
      "fromScreenId": "review-step-screen",
      "toScreenId": "success-step-screen",
      "triggerNodeId": "submit-claim-button",
      "action": "navigate"
    },
    {
      "id": "review-backtrack-flow",
      "fromScreenId": "review-step-screen",
      "toScreenId": "incident-step-screen",
      "triggerNodeId": "edit-incident-button",
      "action": "navigate"
    }
  ],
  "transitions": [
    {
      "id": "policy-error-transition",
      "from": "policy-step-required",
      "to": "policy-step-error",
      "trigger": "submit",
      "description": "Policy step shows validation errors."
    },
    {
      "id": "incident-error-transition",
      "from": "incident-step-required",
      "to": "incident-step-error",
      "trigger": "submit",
      "description": "Incident step shows validation errors or upload failure."
    },
    {
      "id": "claim-submit-transition",
      "from": "claim-submit-loading",
      "to": "claim-submit-success",
      "trigger": "timeout",
      "description": "Submission completes and success confirmation appears."
    }
  ],
  "notes": [
    "Prototype config models form behavior only and does not submit a real claim.",
    "Backtracking preserves entered data; save/resume is a recovery path, not a competing primary action."
  ]
}
