{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omiologic.dev/schemas/ui-blueprint/app-package-metadata.schema.json",
  "title": "App Package Metadata",
  "description": "App-facing package and bundle metadata for local installers, package browsers, and hosted viewers.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "type",
    "id",
    "name",
    "packageVersion",
    "status",
    "surfaces",
    "includes"
  ],
  "properties": {
    "version": {
      "$ref": "#/$defs/version"
    },
    "type": {
      "const": "appPackageMetadata"
    },
    "id": {
      "$ref": "#/$defs/id"
    },
    "name": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "packageVersion": {
      "$ref": "#/$defs/version"
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "active",
        "experimental",
        "deprecated"
      ]
    },
    "bundleType": {
      "type": "string",
      "enum": [
        "individual",
        "componentBundle",
        "aggregateBundle",
        "codexPlugin",
        "claudeLocal",
        "generic"
      ]
    },
    "surfaces": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "codexSkills",
          "codexPlugin",
          "claudeLocal",
          "genericLocal",
          "mcpTool",
          "hostedViewer",
          "packageBrowser"
        ]
      }
    },
    "includes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "skills": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/packageItem"
          }
        },
        "commands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/packageItem"
          }
        },
        "agents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/packageItem"
          }
        },
        "sharedAssets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/packageItem"
          }
        },
        "schemas": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/packageItem"
          }
        }
      }
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifactRef"
      }
    },
    "licenseRef": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "changelogRef": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "generatedAt": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "notes": {
      "$ref": "#/$defs/stringList"
    }
  },
  "$defs": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "stringList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "packageItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "label": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "schemaRef": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "artifactRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "artifactType",
        "path"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "artifactType": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "schemaRef": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "label": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    }
  }
}
