{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omiologic.dev/schemas/ui-blueprint/footer-foundation.schema.json",
  "title": "Footer Foundation",
  "type": "object",
  "additionalProperties": false,
  "required": ["layout", "anatomy", "navigationGroups", "rules", "source", "confidence"],
  "properties": {
    "layout": { "type": "object", "additionalProperties": { "type": "string" } },
    "anatomy": { "type": "array", "items": { "type": "string" } },
    "navigationGroups": { "type": "array", "items": { "type": "string" } },
    "industrySpecificNeeds": { "type": "array", "items": { "type": "string" } },
    "rules": { "type": "array", "items": { "type": "string" } },
    "source": { "type": "string", "enum": ["observed", "inferred", "recommended", "generated", "userProvided"] },
    "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
    "note": { "type": "string" }
  }
}
