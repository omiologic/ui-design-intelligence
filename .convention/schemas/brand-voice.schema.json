{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omiologic.dev/schemas/ui-blueprint/brand-voice.schema.json",
  "title": "Brand Voice",
  "description": "A reusable voice contract for generated UX content, prototype copy, and content models.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "type",
    "id",
    "name",
    "source",
    "audience",
    "tone",
    "avoid",
    "rules",
    "review"
  ],
  "properties": {
    "version": {
      "$ref": "#/$defs/version"
    },
    "type": {
      "const": "brandVoice"
    },
    "id": {
      "$ref": "#/$defs/id"
    },
    "name": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "source": {
      "$ref": "#/$defs/artifactSource"
    },
    "audience": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary",
        "intent"
      ],
      "properties": {
        "primary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "secondary": {
          "$ref": "#/$defs/stringList"
        },
        "intent": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "tone": {
      "$ref": "#/$defs/stringListRequired"
    },
    "avoid": {
      "$ref": "#/$defs/stringListRequired"
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/voiceRule"
      }
    },
    "vocabulary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preferredTerms": {
          "$ref": "#/$defs/stringList"
        },
        "restrictedTerms": {
          "$ref": "#/$defs/stringList"
        },
        "ctaVerbs": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "review": {
      "$ref": "#/$defs/reviewState"
    },
    "notes": {
      "$ref": "#/$defs/stringList"
    }
  },
  "$defs": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "stringList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "stringListRequired": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "sourceKind": {
      "type": "string",
      "enum": [
        "userProvided",
        "generated",
        "derivedFromStudy",
        "derivedFromKnowledge",
        "clientApproved"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "approved"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "reviewed",
        "clientApproved",
        "productionReady",
        "deprecated"
      ]
    },
    "reviewRisk": {
      "type": "string",
      "enum": [
        "medicalClaims",
        "pricingAccuracy",
        "productSpecs",
        "legalCompliance",
        "financialClaims",
        "brandApproval",
        "clientApproval",
        "accessibilityLanguage",
        "translationReview"
      ]
    },
    "artifactSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "confidence",
        "sourceRefs"
      ],
      "properties": {
        "source": {
          "$ref": "#/$defs/sourceKind"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "sourceRefs": {
          "$ref": "#/$defs/stringList"
        },
        "notes": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "reviewState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "needsReview"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/status"
        },
        "needsReview": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reviewRisk"
          }
        },
        "reviewNotes": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "voiceRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "rule",
        "reason"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "rule": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "reason": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "appliesTo": {
          "$ref": "#/$defs/stringList"
        }
      }
    }
  }
}
