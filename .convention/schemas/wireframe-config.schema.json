{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omiologic.dev/schemas/ui-blueprint/wireframe-config.schema.json",
  "title": "UIBlueprint Wireframe Config",
  "description": "MVP schema for schema-valid UI wireframe JSON generated by ui-blueprint-skills.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "label",
    "version",
    "root"
  ],
  "properties": {
    "id": {
      "$ref": "#/$defs/id"
    },
    "type": {
      "const": "wireframe"
    },
    "label": {
      "$ref": "#/$defs/label"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "description": {
      "type": "string"
    },
    "root": {
      "$ref": "#/$defs/node"
    },
    "overlays": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      },
      "default": []
    },
    "responsive": {
      "$ref": "#/$defs/responsive"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean",
          "null"
        ]
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "nodeType": {
      "type": "string",
      "enum": [
        "page",
        "header",
        "footer",
        "main",
        "section",
        "hero",
        "navigation",
        "breadcrumb",
        "contentGroup",
        "textBlock",
        "heading",
        "paragraph",
        "button",
        "buttonGroup",
        "imagePlaceholder",
        "videoPlaceholder",
        "card",
        "cardGrid",
        "list",
        "table",
        "comparisonTable",
        "accordion",
        "tabs",
        "form",
        "inputGroup",
        "dialog",
        "drawer",
        "popover",
        "toast",
        "banner",
        "stickyBar",
        "spacer",
        "divider",
        "annotation"
      ]
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "label"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "$ref": "#/$defs/nodeType"
        },
        "label": {
          "$ref": "#/$defs/label"
        },
        "role": {
          "$ref": "#/$defs/contentRole"
        },
        "layout": {
          "$ref": "#/$defs/layoutPattern"
        },
        "state": {
          "$ref": "#/$defs/interactionState"
        },
        "content": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "boolean",
              "null"
            ]
          }
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/node"
          },
          "default": []
        },
        "responsive": {
          "$ref": "#/$defs/responsive"
        },
        "accessibility": {
          "$ref": "#/$defs/accessibility"
        },
        "annotations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "responsive": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "desktop": {
          "type": "string"
        },
        "tablet": {
          "type": "string"
        },
        "mobile": {
          "type": "string"
        }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "landmark": {
          "type": "string"
        },
        "ariaLabel": {
          "type": "string"
        },
        "focusManagement": {
          "type": "string"
        },
        "keyboardBehavior": {
          "type": "string"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "contentRole": {
      "type": "string",
      "enum": [
        "eyebrow",
        "headline",
        "subheadline",
        "body",
        "caption",
        "label",
        "helperText",
        "errorText",
        "primaryCTA",
        "secondaryCTA",
        "tertiaryCTA",
        "navigationItem",
        "breadcrumbItem",
        "trustSignal",
        "testimonial",
        "metadata",
        "price",
        "badge",
        "emptyState",
        "legal"
      ]
    },
    "layoutPattern": {
      "type": "string",
      "enum": [
        "singleColumn",
        "twoColumn",
        "threeColumn",
        "sidebar",
        "splitHero",
        "centeredHero",
        "mediaLeft",
        "mediaRight",
        "cardGrid",
        "featureGrid",
        "comparisonGrid",
        "stackedSections",
        "inlineForm",
        "stepper",
        "tabs",
        "accordion",
        "stickyHeader",
        "stickyFooterBar",
        "modalOverlay",
        "drawerPanel"
      ]
    },
    "interactionState": {
      "type": "string",
      "enum": [
        "default",
        "hover",
        "focus",
        "active",
        "selected",
        "disabled",
        "expanded",
        "collapsed",
        "open",
        "closed",
        "loading",
        "success",
        "warning",
        "error",
        "empty",
        "hidden",
        "visible",
        "sticky",
        "dismissible",
        "required",
        "optional"
      ]
    }
  }
}
