{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omiologic.dev/schemas/ui-blueprint/palette-foundation.schema.json",
  "title": "Palette Foundation",
  "type": "object",
  "additionalProperties": false,
  "required": ["mode", "colors", "accessibilityNotes"],
  "properties": {
    "mode": { "type": "string", "enum": ["light", "dark", "mixed", "unknown"] },
    "colors": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/colorToken" }
    },
    "accessibilityNotes": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "sourceKind": { "type": "string", "enum": ["observed", "inferred", "recommended", "generated", "userProvided"] },
    "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
    "colorToken": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "value", "intent", "usage", "source", "confidence"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "value": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "intent": { "type": "string", "minLength": 1 },
        "usage": { "type": "string", "minLength": 1 },
        "useOn": { "type": "array", "items": { "type": "string" } },
        "doNotUseOn": { "type": "array", "items": { "type": "string" } },
        "accessibilityNotes": { "type": "array", "items": { "type": "string" } },
        "source": { "$ref": "#/$defs/sourceKind" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "note": { "type": "string" }
      }
    }
  }
}
